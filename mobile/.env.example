# Wahla FastAPI backend base URL. Pick the value matching your target:
#   Web (expo start --web) or iOS simulator:  http://localhost:8000
#   Android emulator:                          http://10.0.2.2:8000
#   Physical device on the same LAN:           http://<your-machine-LAN-IP>:8000
#                                               (run uvicorn with --host 0.0.0.0)
EXPO_PUBLIC_API_URL=http://localhost:8000
